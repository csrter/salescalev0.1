# Copy to .env and fill in. NEVER commit the real .env.

# --- Core ---
# Postgres in production; falls back to SQLite for local dev if unset
DATABASE_URL=postgresql+psycopg2://salescale:salescale@localhost:5432/salescale
JWT_SECRET=change-me-generate-a-long-random-string
# Fernet key for encrypting platform tokens at rest.
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# --- Meta (Marketing API v25.0) ---
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:8000/api/connect/meta/callback
META_API_VERSION=v25.0

# --- Google Ads (API v24) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_DEVELOPER_TOKEN=
# Atlas Reach MCC (manager account) customer ID, digits only
GOOGLE_LOGIN_CUSTOMER_ID=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/connect/google/callback

# --- App ---
FRONTEND_ORIGIN=http://localhost:5173
